{
  "rules": {
    ".read": false,
    ".write": false,

    "config": {
      ".read": false,
      ".write": false
    },

    "canli": {
      ".read": "auth != null",
      ".write": "auth != null && root.child('amigolar').child(auth.uid).child('durum').val() === 'onaylandi'"
    },

    "besteler": {
      ".read": "auth != null",
      ".write": "auth != null && root.child('amigolar').child(auth.uid).child('durum').val() === 'onaylandi'"
    },

    "amigolar": {
      ".read": "auth != null && auth.uid === 'ADMIN_UID_BURAYA'",
      "$uid": {
        ".read": "auth != null && (auth.uid === $uid || auth.uid === 'ADMIN_UID_BURAYA')",
        ".write": "auth != null && (auth.uid === 'ADMIN_UID_BURAYA' || (auth.uid === $uid && !data.exists() && newData.child('durum').val() === 'bekliyor' && newData.child('amigoSifre').val() === root.child('config').child('amigo_sifre').val()))",
        ".validate": "newData.hasChildren(['isim', 'durum'])"
      }
    },

    "katilimcilar": {
      ".read": "auth != null && auth.uid === 'ADMIN_UID_BURAYA'",
      "$uid": {
        ".read": "auth != null && (auth.uid === $uid || auth.uid === 'ADMIN_UID_BURAYA')",
        ".write": "auth != null && (auth.uid === $uid || auth.uid === 'ADMIN_UID_BURAYA')",
        ".validate": "newData.hasChildren(['isim', 'bolge'])"
      }
    }
  }
}
